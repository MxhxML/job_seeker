     "text": [
      "0                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Descriptif du poste\\n\\nPoste et missions\\n\\nRattaché(e) au Responsable de Service CRM Digital vous participez au développement de la performance commerciale de la Banque de Détail en rejoignant une équipe au cœur de la stratégie de contact client.\\nEn relation avec les départements Études, Marketing Client, Marketing de l'Offre et Communication Commerciale votre rôle sera de penser et mettre en place des actions 360 pour générer du trafic, qualifier les leads et développer ventes issues des environnements digitaux.\\n\\nAccompagné(e) par votre manager, vous gagnerez progressivement en autonomie pour remplir vos missions :\\n\\nVous participez aux comités décisionnels pour concevoir les actions marketing (choix des canaux, planification, priorisation, mise en cohérence des cibles, des contenus etc.).\\nVous contribuez à la configuration des ciblages des campagnes dans l'outil CRM (Adobe Campaign) pour le marketing direct et l'outil de personnalisation en ligne (Kameleoon).\\nVous mesurez la performance des actions sur Adobe Analytics et Power BI, créez des rapports automatiques et partagez des bilans et analyses.\\nVous rejoignez la filière nationale Business Digital au niveau du groupe et accompagnez la montée en puissance de la stratégie marketing digital au niveau du Groupe BPCE mais aussi sa déclianaison à l'échelle de la CEIDF.\\nVous rédigez et partagez des comptes-rendus et participez à la mise en avant de l'activité du service.\\n\\nIl est possible de bénéficier de quelques jours de télétravail sur ce poste.\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nÉtudiant(e) de niveau Bac +4/5 en marketing, data ou gestion de la relation client avec un fort attrait pour le digital vous bénéficiez dans l'idéal d'une première expérience dans la mise en place d'action marketing en ligne.\\n\\nDoté(e) d'une bonne connaissance de l'environnement web et du e-commerce vous souhaitez développer vos compétences techniques tout en ayant une vision centrale sur un plan d'action 360.\\n\\nArmé(e) de votre capacité d'analyse, votre aisance relationnelle et votre créativité, vous serez capable d'être force de proposition pour challenger l'existant et améliorer la performance dans un cadre collaboratif.\\n\\nLa connaissance ou une précédente expérience sur des outils Analytics (Adobe Analytics, Matomo, Google Analytics…) et/ou CRM (Adobe Campaign, Salesforce, Imagino, Marketo…) sont un vrai plus.\\n\\nLa connaissance d'HTML/CSS est également appréciée.\n",
      "1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Descriptif du poste\\n\\nLe Mot du manager :\\n\\n« Rejoindre notre équipe, c'est intégrer un collectif dynamique, bienveillant et engagé, où l'esprit d'équipe et le sens du service sont au cœur de notre quotidien. Nous attachons une grande importance à l'entraide, à la rigueur et à l'impact de notre travail. Si vous voulez apprendre, contribuer à des projets porteurs de sens et évoluer dans un environnement stimulant, cette alternance est faite pour vous ! ».\\n\\nDescriptif du poste :\\n\\nLe service Marketing se compose de plusieurs services dont notamment le service MOAD Marketing et le service Marketing analytique.\\n\\nAu sein du service Marketing MOAD - Vous serez en charge de réaliser les missions suivantes :\\n\\n1. Dans le cadre de la construction des campagnes marketing\\n\\nRéaliser et optimiser les traitements de données ;\\nEffectuer des ciblages pour les opérations Marketing : Elaborer des scripts d'interrogation de données sous SQL ou dans la base de données de l'outil d'envoi ;\\nParamétrer des modèles de campagnes à partir du logiciel d'envoi Adobe Campaign.\\n\\n2. Dans le cadre de l'activité de l'administration fonctionnelle de l'outil d'envoi de campagnes :\\n\\nParticiper aux évolutions des outils d'envoi de campagnes marketing à partir du logiciel ADOBE CAMPAIGN, en co-pilotage avec le consultant MOAD, la MOA et le pilote de recette ;\\nRéaliser et rédiger le compte-rendu des tests de pré production réalisés ;\\nMettre à jour les supports ;\\nEffectuer l'accompagnement fonctionnel et opérationnel des Centres Régionaux de Promotion Osmose (centres d'envoi des campagnes marketing) ;\\nÊtre le support de niveau 2 auprès des CRPO (aide à la création et au paramétrage des campagnes).\\n\\nAu sein du service Marketing analytique - Vous serez en charge de réaliser les missions suivantes :\\n\\nStructurer, gérer des bases de données et en assurer la maintenance ;\\nRéaliser et optimiser les traitements de données ;\\nEffectuer des ciblages pour des opérations marketing, ainsi que conseiller et en assurer la faisabilité ;\\nElaborer des scripts d'interrogation de données ;\\nMettre en place des outils d'aide à la décision (tableaux de bord, outils de pilotage, indicateurs, …) ;\\nConduire des études Marketing et analyser les résultats obtenus ;\\nPrésenter les résultats d'analyses et les conclusions des différentes études et expérimentations ;\\nRéaliser le bilan des actions menées et la production des KPIs.\\n\\nComme tous les salariés de l'organisme, vous devrez vous conformer aux exigences de la Politique de Sécurité du Système d'Information de l'organisme (PSSI).\\n\\nInformations complémentaires\\n\\nDate de prise de fonction : Septembre 2026 ;\\nCe poste est basé à Lille, site accessible en métro ;\\nRémunération selon la grille conventionnelle du personnel administratif, l'âge et le niveau d'études ;\\nVersement d'une Gratification au titre du 13ème mois au prorata du temps de présence dans l'organisme et d'une prime de 14ème mois sous conditions ;\\nPrise en charge avantageuse de l'abonnement de transport et contribution aux frais de déplacements réalisés dans le cadre des mobilités douces ;\\nTickets restaurant d'une valeur de 11,51 € dont 6.91 € de part patronale et, 4,60 € de part salariale ;\\nMise à disposition de frigos connectés ;\\nTélétravail possible selon l'accord en vigueur.\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\nVous êtes en 3ème année d'un BUT (sciences des données ou STID) ou en master Marketing data Science (ou data analyst) ;\\nVous maitrisez les outils bureautiques (Pack Office) et disposez de compétences en statistiques ainsi qu'en organisation et fonctionnement des bases de données et des systèmes d'information ;\\nVous connaissez idéalement le langage de programmation : SQL, VB, VBA, les outils de cartographie et de data visualisation (Power BI) ;\\nAutonome et curieux(se), vous faites également reconnu(e) votre capacité d'analyse ;\\nVous faites preuve d'adaptabilité et de rigueur dans un environnement nécessitant de respecter et faire respecter les échéances ;\\nDoté(e) d'un esprit équipe et d'une aisance relationnelle, vous possédez aussi des qualités rédactionnelles.\\n\\nVous reconnaissez-vous dans cette annonce ?\\n\\n\\nPour postuler, veuillez transmettre votre CV et votre lettre de motivation via le lien suivant : https://recrutement.cpam-lille-douai.fr/fr/s/ZE8y4Y5R\\n\\nVous souhaitez en savoir plus sur la CPAM de Lille-Douai, retrouvez-nous sur notre site carrière :\\n\\nhttps://recrutement.cpam-lille-douai.fr/fr\\n\\nVoir plus\n",
      "2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     Descriptif du poste\\nCompany Description\\n\\nChez Kiabi, notre mission est de faciliter la vie des familles, en tissant ensemble une mode responsable et des solutions durables.\\n\\nNos Kiabers sont la clé de la success story Kiabi. Pour que Kiabi soit durablement une entreprise Great Place to Work, nous veillons à ce que chacun puisse s’épanouir, se développer et vivre une expérience unique.\\n\\n« Vivre un métier que nous aimons, avec des personnes que nous aimons pour des clients que nous aimons. »\\n\\n\\n\\n\\nPourquoi nous rejoindre ?\\n\\nEntreprise certifiée Great Place to Work dans tous nos pays\\nUn parcours complet d’intégration et de formations\\nRémunération au-delà du légal (100% du SMIC pour les BAC+4/+5)\\nRemise de 25% sur les produits KIABI\\nActionnariat : hausse de 7,99% de la valeur de part en 2025\\nDes missions responsabilisantes et un vrai impact business\\n\\n\\n\\nC’est pour cela, et bien plus encore, que Ici, c’est Kiabi !\\n\\nRejoins-nous ! 😊\\n\\nJob Description\\n\\nVotre mission :\\n\\nAu sein de l’équipe Connaissance Client, vous contribuerez activement à améliorer la compréhension des clients à l’échelle internationale. Votre mission : analyser les comportements clients, construire des études et produire des insights clairs et actionnables, puis les partager aux équipes métiers pour éclairer leurs décisions.\\n\\nVos principales responsabilités :\\n\\nRéaliser des analyses ad hoc et des études sur le comportement et les attentes clients, en lien avec les différentes équipes de l'entreprise (marketing, digital, produits, …).\\nConstruire des restitutions synthétiques et impactantes et les partager aux équipes métiers.\\nDébriefer les actions ou opérations commerciales, en analysant leur impact sur les clients et en formulant des recommandations.\\nAccompagner les équipes métiers au quotidien dans l’interprétation des données et la prise de décision orientée client.\\nContribuer à faire vivre la culture client dans toute l’entreprise, en accompagnant les équipes métiers dans l'interprétation des données et en valorisant les insights en découlant.\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nProfil recherché :\\n\\nÉtudiant(e) Bac+4/5 en data, marketing ou statistiques.\\nÀ l’aise avec les outils d’analyse de données (SQL, Power BI/Tableau, Excel, Python apprécié).\\nBonne compréhension des enjeux liés à la connaissance client et à l’expérience utilisateur.\\nEsprit analytique, rigueur et curiosité intellectuelle. Avoir une vraie envie de faire parler la donnée  et de comprendre le \"pourquoi\" derrière les chiffres.\\nBon niveau d’anglais, à l’écrit comme à l’oral (B1 minimum)\\nSens de la communication, aisance à l'oral et envie de travailler en équipe.\\nAdditional Information\\n\\nKIABI est une entreprise inclusive et s’engage à étudier toutes les candidatures, à compétences égales.  \\n\\nPour en savoir plus sur KIABI, nous t'invitons à consulter notre site carrière.\n",
      "3                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  Descriptif du poste\\n\\nVos missions au quotidien\\n\\nVous savez “ faire parler “ les données pour créer de la valeur ? Vous souhaitez travailler en mode agile ? Rejoignez-nous !\\n\\nAu sein de la ligne métier Payment & Cash Management (PCM), vous serez rattaché à la Direction des Solutions et contribuerez à des missions à forte valeur ajoutée, au cœur des enjeux de performance des services et produits destinés à notre clientèle Corporate, en France comme à l’international.\\n\\nDans un environnement complexe, international et en pleine transformation, la data est un levier stratégique clé. Votre rôle sera de transformer des données financières et opérationnelles en indicateurs clairs, fiables et actionnables, au service de la prise de décision business et du pilotage de la performance.\\n\\n\\nExploiter la puissance de la donnée\\n\\nVous collectez, structurez et fiabilisez des données issues de multiples sources (finance, IT, opérations) afin d’analyser les coûts, l’activité et comprendre les leviers de performance.\\nDonner du sens grâce à la dataviz\\n\\nVous concevez et développez des dashboards Power BI interactifs, pensés pour les managers et les équipes métiers, afin de faciliter le pilotage de l’activité et l’arbitrage stratégique.\\nAnalyser, comprendre, proposer\\n\\nVous analysez les tendances, mettez en évidence des opportunités d’optimisation, et êtes force de proposition sur des sujets à forts enjeux : performance économique, allocation des coûts, efficacité opérationnelle.\\n\\nEt si c’était vous ?\\n\\n\\nVous préparez un Bac + 4/5 en Ecole de commerce, d’ingénieurs ou équivalent avec une spécialisation Data.\\nVous avez une appétence pour le traitement des données et pour la stratégie d’entreprise.\\nVous maitrisez les techniques de traitement et de structuration des données (Excel avancé / PowerQuery / SQL / Python).\\nVous avez la capacité à créer des rapports interactifs et à gérer des modèles de données (PowerBI).\\nVous savez faire preuve de rigueur, d’esprit d’initiative et savez présenter des résultats de manière claire et synthétique.\\nVous êtes bon communicant en français et en anglais (You’re fluent in English!)\\nVous êtes notre candidat idéal !\\n\\nPensez à accompagner votre CV de votre planning de formation !\\n\\nPlus qu’un poste, un tremplin\\n\\nRejoignez-nous pour faire grandir vos ambitions ! Dès votre arrivée, vous serez intégré dans nos équipes et apprendrez chaque jour aux côtés de nos experts qui vous accompagneront dans vos missions. Progressivement, vous gagnerez en autonomie sur vos projets pour faire de cette expérience un vrai accélérateur de carrière. Vous découvrirez également toute la diversité de nos métiers, dans un secteur qui évolue et innove en permanence.\\n\\nA la fin de vos études, diverses opportunités pourront s’offrir à vous, en France et à l’international.\\n\\nPourquoi nous choisir ?\\n\\nAttentif à votre qualité de vie et conditions de travail, vous bénéficiez d’avantages :\\n\\nPrime de participation et d’intéressement\\nTélétravail possible selon le rythme de votre service et celui de votre alternance\\nPrise en charge de 60% de votre titre de transport\\nBilletterie à prix réduits de notre Comité d’Entreprise (concerts, cinéma, sport…).\\nOffre variée de restaurants d’entreprise et de cafétérias à tarifs compétitifs ainsi que des titres restaurants dématérialisés quand vous êtes en télétravail\\n\\nSi vous avez 3 mois d’ancienneté sur l’exercice de référence\\n\\nCréer, oser, innover, entreprendre font partie de notre ADN. Si vous aussi vous souhaitez être dans l’action, évoluer dans un environnement stimulant et bienveillant, vous sentir utile au quotidien et développer ou renforcer votre expertise, nous sommes faits pour nous rencontrer !\\n\\nVous hésitez encore ?\\nSachez que nos collaborateurs peuvent s’engager quelques jours par an pour des actions de solidarité sur leur temps de travail : parrainer des personnes en difficulté dans leur orientation ou leur insertion professionnelle, participer à l’éducation financière de jeunes en apprentissage ou encore partager leurs compétences avec une association. Les formats d’engagement sont multiples.\\n\\nDiversité et inclusion\\n\\nNous sommes un employeur garantissant l’égalité des chances et nous sommes fiers de faire de la diversité une force pour notre entreprise. Le groupe s’engage à reconnaître et à promouvoir tous les talents, quels que soient leurs croyances, âge, handicap, parentalité, origine ethnique, nationalité, identité de genre, orientation sexuelle, appartenance à une organisation politique, religieuse, syndicale ou à une minorité, ou toute autre caractéristique qui pourrait faire l’objet d’une discrimination.\\n\\nTransparence et responsabilité\\n\\nLe groupe Société Générale a à coeur que les personnes qui nous rejoignent agissent avec éthique et responsabilité pour une culture de performance durable. Les informations mentionnées dans votre candidature peuvent potentiellement être vérifiées dans le respect du cadre légal, à tout moment pendant le processus de recrutement.\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\n\n",
      "4                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              Descriptif du poste\\n\\n<![CDATA[\\n\\nAU QUOTIDIEN ÇA DONNE QUOI ?\\n\\n\\nVous suivrez un parcours de découverte des différentes activités du Data Office Risk Finance Operational Norms en collaboration avec les membres de l’équipe. \\n \\nDans le cadre de votre alternance, vos principales missions seront de : \\n\\nParticiper à accroitre la fiabilité, l’exhaustivité et la qualité des données produites à des fins de reportings en participant activement au processus de Grammaire Commune (i.e langage commun (dictionnaire de données))\\nContribuer au renforcement de l’application des instructions émises par l’équipe au travers du Groupe\\nAssister l’équipe dans les travaux de normalisation des exigences règlementaires.\\n\\n\\n\\n\\nCes activités seront conduites en interaction avec des équipes Groupe, Risk et Finance ainsi qu’avec nos entités situées à l’international. Ce parcours sera adapté en fonction des connaissances et compétences du collaborateur et des impératifs du service.\\n\\nLes missions c’est important, l’équipe et l’environnement aussi ! \\n \\nRISK est une fonction intégrée et indépendante, et fait partie des fonctions de contrôle du Groupe BNP Paribas. Elle est la seconde ligne de défense indépendante du Groupe sur les activités de gestion des risques, qui sont sous sa responsabilité directe, dont les risques de crédit et de contrepartie, les risques de marché, les risques de financement et de liquidité, les taux d’intérêts et les risques de change du portefeuille bancaire, les risques d’assurance, le risque opérationnel et les risques environnementaux et sociaux. \\n \\nL’équipe Data Office Risk Finance Operational Norms est une équipe transverse aux périmètres des fonctions RISK et Finance. Rejoindre l’équipe vous apportera une connaissance règlementaire transverse à l’ensemble des reporting du Groupe et multi-Métiers. Vous serez amené notamment à développer votre réseau en travaillant au quotidien avec de nombreux interlocuteurs (experts règlementaires, MOAs, entités etc.…), développer des compétences règlementaires en gestion de projet et travailler dans un environnement dynamique. Vous découvrirez l’importance du travail en équipe pour répondre à la transversalité des sujets et la diversité des compétences requises. \\n \\nVotre camp de base sera le Millénaire 1, situé à Paris.\\n\\nNos tuteurs et tutrices se forment en continu pour mieux vous accompagner dans toutes les composantes de votre alternance, toujours avec bienveillance. Une partie de leur temps de travail est d’ailleurs dédiée à votre encadrement : conseils de méthodes de travail, aide à la maîtrise du temps, développement d’une posture professionnelle… De quoi vous sentir bien dès votre arrivée ! Trois temps forts d’évaluation de votre alternance sont prévus, à l’issue de votre période d’essai, à mi-parcours et en ﬁn de contrat. \\n\\n \\n\\nCe poste, basé à Paris, est à pourvoir à partir de 02 septembre 2026 pour une durée de 12 ou 24 mois.  \\n\\n \\n\\nET APRES ?\\n\\nUne expérience dans l’équipe Data Office Risk Finance Operational Norms est une opportunité rare de découvrir l’organisation d’une banque autour des exigences règlementaires imposées par le régulateur, l’articulation entre ses différentes équipes et les contraintes auxquelles un grand groupe bancaire doit faire face.\\n\\nVous découvrirez l’organisation et le fonctionnement d’une Fonction mondiale intégrée. Grâce à cette position transverse et vos interactions avec les différentes entités du Groupe, vous construirez un réseau solide et ferez la différence pour vos prochains stages ou premier emploi.\\n\\n \\n\\nD’autres opportunités pourront s’offrir à vous, favorisant votre insertion professionnelle :\\n\\nLe Graduate Programme vous permet de booster votre avenir, de développer vos compétences et votre leadership grâce à des missions à responsabilité ;\\nLe Volontariat International en Entreprise vous donne l’opportunité d’enrichir votre parcours avec une expérience internationale unique de 12 à 24 mois.\\n\\n \\n\\nLES AVANTAGES A NOUS REJOINDRE\\n\\nTravailler chez BNP Paribas c’est :\\n\\nUn package rémunération et des avantages :\\n\\nUne rémunération mensuelle entre 1566 € et 2373 € brut pour la préparation d’un diplôme de niveau bac+4/5, versée sur 12 mois. Son montant prendra en compte le type de contrat (apprentissage ou professionnalisation), votre formation et votre âge conformément à la réglementation applicable.\\nAccords d’entreprise et de groupe, plan épargne entreprise/retraite, intéressement et participation, accès au restaurant d’entreprise et /ou tickets restaurant, couverture santé et prévoyance, activités sociales et culturelles via le comité social et économique, …\\nDe la flexibilité avec un rythme de travail hybride selon l’environnement de travail et les règles de l’entreprise, à définir avec votre tuteur\\nCinq jours de révisions pour vos examens si vous êtes en contrat d’apprentissage\\n\\n \\n\\nETES-VOUS NOTRE PROCHAIN ALTERNANT DATA MANAGEMENT ANALYST H/F ? \\n\\nVous préparez un diplôme de niveau BAC+ 4/5 reconnu RNCP en école de commerce, d’ingénieur ou équivalent universitaire avec une spécialisation en Finance et Data.\\n\\nVous parlez couramment Français et Anglais. \\nVous maitrisez le pack Office.\\nVotre adaptabilité et votre capacité à collaborer vous permettent de créer des liens de confiance.  Ajoutez à cela un bon sens de l’organisation et une bonne capacité d’analyse pour finir de nous convaincre !\\n\\n\\n\\n\\nLES PROCHAINES ÉTAPES ?\\n\\nPour poursuivre le processus de candidature avec nous, trois étapes vous attendent :\\n\\n\\n  1- Vous réussissez les étapes de pré-sélection (tests en ligne)\\n  2- Nos recruteurs analysent votre candidature dans les meilleurs délais\\n  3- Vous passez un à deux entretiens managers \\n\\n\\n\\n\\nVos compétences sont validées et votre profil est retenu ? Bienvenue chez BNP Paribas.\\n\\nCes tests sont éliminatoires, prenez le temps de les réaliser dans de bonnes conditions.\\n\\n\\n« La Diversité, l’Egalité et l’Inclusion sont au cœur de nos valeurs et nous accueillons, sans distinction, tous les talents. »\\n\\nChez BNP Paribas, ce sont vos compétences qui font la différence, pas votre handicap ! Envoyez votre CV à l’Équipe Recrutement Mission Handicap : missionhandicap@bnpparibas.com.\\n\\n\\nL’éthique, au cœur de notre recrutement\\n\\nNous veillons à ce que chaque candidat agisse avec intégrité.\\n\\nLes informations fournies (CV, identité, antécédents) peuvent être vérifiées à tout moment du processus.\\n\\n]]>\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\n\n",
      "5                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Descriptif du poste\\n\\nALTERNANCE 12 MOIS - A partir de Septembre 2026 - DATA ANALYST ENVIRONNEMENT - Master 1/2\\n\\nLife is too short for a boring career!\\n\\nChez L’Oréal Groupe, la routine n’existe pas, ici, la créativité est un super-pouvoir qui transforme chaque idée en un impact majeur.\\n\\nNotre environnement de travail doit autant nous faire vibrer que nos passions. Que ce soit au sein de nos marques iconiques, sur des marchés internationaux, ou à travers nos multiples divisions, les opportunités de grandir, ici, sont juste… illimitées.\\n\\n90% de nos alternants sont fiers de travailler au sein du groupe L’Oréal.\\n\\n88% de nos alternants recommandent L’Oréal pour y effectuer un stage.\\n\\n(Enquête interne “Care Connect Survey” novembre 2025)\\n\\nPrêt à vivre cette expérience unique ? Ne perdez pas de temps et découvrez notre offre.\\n\\nVos Missions\\n\\nNous recherchons un(e) futur(e) expert(e) de la donnée, capable de transformer des flux complexes en leviers de décision stratégiques. En postulant à cette offre, vous aurez l’opportunité d’intégrer l’une de nos équipes en charge du pilotage de la performance environnementale du Groupe.\\n\\nVos missions s’articuleront autour de axes suivants :\\n\\n1. Data Analysis & Insights :\\n\\n\\nDévelopper et optimiser des dashboards sous Power BI pour rendre la donnée “parlante” et faciliter la prise de décision.\\nTransformer des données brutes complexes en insights clairs pour améliorer notre empreinte environnementale globale.\\nParticiper à la construction de la roadmap d’analyse de données de l’équipe.\\n\\n2. Reporting & Qualité de la donnée :\\n\\nConsolider les données environnementales pour nos publications officielles (Rapport Annuel, audits externes).\\nGarantir la fiabilité des données via des processus de validation rigoureux avec les différents métiers du Groupe.\\nPour le volet Carbone : Améliorer les facteurs d’émission et les tables de mapping dans nos outils de consolidation (SWEEP).\\n\\n3. Transformation Digitale & Outils :\\n\\nContribuer à l’amélioration de nos écosystèmes digitaux dédiés à la gestion des risques et de la performance.\\nOptimiser les flux de données avec les “Métiers” pour gagner en agilité et en précision.\\n\\n4. Support aux projets stratégiques :\\n\\nSoutenir le déploiement de projets EHS globaux ou de campagnes spécifiques de collecte de données.\\nRéaliser des benchmarks sur les meilleures pratiques du marché pour challenger nos opérations.\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nVotre Profil\\n\\n\\nVous êtes étudiant(e) en Master (Bac+4/5) au sein d’une école d’ingénieur, d’une école de commerce ou d’une université avec une spécialisation en Environnement, Développement durable ou Ingénierie de la donnée, à la recherche d’une alternance d’un an.\\nVous avez une forte appétence pour l’analyse de données et les enjeux de performance environnementale (bilan carbone, reporting EHS).\\nVous maîtrisez les outils informatiques d’analyse et de data-visualisation, en particulier Power BI et Excel.\\nVous parlez couramment anglais et français.\\nVous avez un esprit analytique et rigoureux, êtes précis(e), organisé(e) et doté(e) d’excellentes capacités de communication et de conviction.\\nVotre proactivité et votre aptitude à travailler en équipe dans un environnement exigeant et en constante évolution seront des atouts majeurs.\\n\\n\\nVos avantages\\n\\nPrime d’intéressement et de participation annuelle\\nMutuelle santé et Prévoyance\\nPlan d’Epargne Groupe\\nComité d’entreprise (CSE)\\n75 % des frais de transport pris en charge par L’Oréal Groupe\\n1 jour de télétravail parsemaine\\n25 jours de congés par an (2,08 jours/mois)\\n8 jours de repos par an (RTT)\\n\\nLes + Groupe L’Oréal : Accès à L’Oréal Learning Platform pour booster votre développement, Vente Au Personnel à des tarifs préférentiels, vente flash Friends & Family pour votre entourage.\\n\\nEt selon les campus : Salle de sport & Conciergerie.\\n\\nLe process de recrutement\\n\\n1. Entretien recruteur - 30 min : pour vous présenter et échanger sur le poste & le Groupe L’Oréal\\n\\n2. Rencontre avec votre potentiel futur manager - 45 min : pour échanger sur les missions du poste\\n\\nLe Groupe L’Oréal\\n\\nRejoignez L’Oréal, le leader mondial de la beauté, présent dans plus de 150 pays avec un portefeuille de 37 marques internationales réparties en quatre divisions : Produits Grand Public, Produits Professionnels, Beauté Dermatologique et Luxe.\\n\\nChez L’Oréal, nous créons une beauté qui agit, inspire et rassemble. Notre mission est d’inventer le futur de la beauté en combinant le meilleur de la technologie, de la science et de l’inspiration naturelle et offrir à chacun\\n• e une beauté inclusive, responsable et tournée vers l’avenir.\\n\\nEt parce que l’égalité des chances et la diversité sont des valeurs fortes au sein du Groupe, en tant que leader de la beauté, nous considérons chaque candidature.\\n\\nQuelle que soit votre identité de genre, votre orientation sexuelle, votre ou vos handicap(s) visible(s) et/ou invisible(s), vos origines sociales ou culturelles, votre état de santé, votre âge, votre religion ou tout autre élément qui vous rend unique, nos équipes étudieront votre profil avec attention.\\n\\nVoir plus\n",
      "6                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             Descriptif du poste\\n\\nAbout Mirakl:\\n\\nFounded in 2012, Mirakl has been at the forefront of marketplace innovation, empowering every business to compete in the platform economy.\\n\\nToday, Mirakl’s operating system combines an enterprise marketplace solution (Mirakl Platform) that enables retailers and B2B organizations to launch, scale, and operate marketplaces and dropship, AI-powered multichannel selling (Mirakl Connect), retail media (Mirakl Ads) and an agentic commerce infrastructure (Mirakl Nexus).\\n\\nWith dual headquarters in Boston and Paris, Mirakl helps a global ecosystem of 450+ marketplaces (B2C and B2B) and a network of over 100k third-party marketplace sellers. Brands like Macy’s, Decathlon, Carrefour, Asos, and Airbus Helicopters use Mirakl to grow their businesses in new and remarkable ways.\\n\\nFor more information, visit www.mirakl.com.\\n\\nMirakl in Numbers:\\n\\n🗓️ Founded in 2012 | Member of French Tech Next40\\n👥 750+ employees in 9 offices worldwide: Paris, Barcelona, Bordeaux, Boston, London, Munich, New York, Sydney, Tokyo\\n\\nOur Values:\\n\\nWorking at Mirakl means accelerating your career alongside ambitious, passionate, and supportive colleagues. We're proud of the diversity of backgrounds, perspectives, and experiences that make our teams unique.\\n\\nOur 5 values guide how we collaborate:\\n\\n💡 Work Hard Together: Teamwork and collaboration are the foundation of our success\\n🏆 Get Things Done: We prioritize action and efficiency for impactful results\\n🚀 Go Above & Beyond: We tackle challenges proactively and always aim for excellence\\n🎓 Succeed Through Expertise: Knowledge sharing and continuous learning are core to our culture\\n🤝 Satisfy & Empower Clients: We're committed to our clients' success\\n\\nThe Team You'll Join\\n\\nYou'll join the Platform Advisory team led by Laura, EMEA Manager Platform Advisory, within the Sales Acceleration department. The team consists of 5 Business Consultants who support Mirakl's prospects in defining their marketplace strategies and developing compelling business cases.\\n\\nAs a Sales Data Analyst Apprentice, you'll play a crucial role in accelerating the implementation of Mirakl's vertical go-to-market strategy by providing data-driven insights that power sales prospecting, consulting engagements, and business case development. You'll collaborate closely with the a global team, Business Development Representatives, and the broader Go-to-Market organization.\\n\\n12-month apprenticeship starting September 2026 | Based in Paris\\n\\nYour Impact\\nBuild scalable data pipelines: Retrieve and analyze prospect data through advanced technologies including web scraping, API calls, and Python (pandas library) to generate strong, reliable, and actionable insights for Mirakl's Sales and Partner ecosystem teams\\nTransform data into sales enablement tools: Create personalized email insights and slide decks that support sales prospecting efforts and inform the Platform Advisory Team's consulting engagements and business case development\\nAccelerate personalized outreach: Collaborate with the Business Development Representative team to create persona-based outreach materials (e.g., CEO-focused presentations, Head of e-commerce email sequences) that increase conversion rates\\nLeverage AI to improve efficiency: Utilize AI (LLMs) to automate data analysis, enhance content personalization, and streamline operational workflows\\nSupport strategic decision-making: Provide analytical insights that help sales teams prioritize opportunities, refine targeting strategies, and optimize the vertical go-to-market approach\\nWhat You'll Bring to the Role\\n\\nEducation\\n\\nCurrently pursuing higher education in Business Analytics, Data Science, Engineering (Computer Science/Data), Management, or a related field\\n\\nExperience\\n\\nIdeally, experience working on projects supporting sales teams (sales, sales ops, or revenue ops)\\n\\nTechnical Skills\\n\\nProficient in Python with hands-on experience using the pandas library for data manipulation\\nExperience with web scraping libraries (e.g., BeautifulSoup, Scrapy, Selenium)\\nComfortable with HTML structure and parsing\\nStrong knowledge of API calls and REST API integration\\nProficient in SQL for data extraction and analysis\\nBasic knowledge of AI (LLM) and the ability to utilize it to improve efficiency\\n\\nSkills\\n\\nAbility to be laser-focused on a singular task with tenacity to always solve problems regardless of hurdles faced\\nAcute attention to detail paired with commendable analytical prowess\\nSolid grasp of technological advancements and their utility in elevating operational efficiency\\nTeam player: You collaborate effectively with international teams and share best practices\\n\\nLanguages\\n\\nFluent in English and French (written and spoken) required, as you'll be collaborating with a EMEA & US-based team\\nWhat We Offer You\\n\\nBeing a student at Mirakl you have:\\n\\nA meaningful experience with empowering missions\\nA dynamic and stimulating work environment with passionate Mirakl workers\\nThe opportunity to be at the heart of a French unicorn at a unique stage of its development\\nA real interns and apprentices community, our #miraklinterns\\n\\nBenefits:\\n\\nApprenticeship compensation\\nSwile meal voucher card\\nTransportation costs covered: Navigo at 50%, bike reimbursement, etc.\\nAccess to CSE discounts (ticketing, entertainment, etc.)\\nA healthy mind in a healthy body: Take time for yourself with the Gymlib pass!\\nA tailor-made integration path to quickly gain skills\\nEmpowering and evolving missions to get the most out of this experience\\nOur Hiring Process\\n\\nWe warmly encourage you to apply to any of our roles, even if you think you're not an exact match.\\n\\nPlease click the \"Apply\" button to submit your application—this helps us make the best possible assessment and get back to you as quickly as possible.\\n\\nAI-powered screening conversation (10 min) with Emma, Mirakl's AI Talent Ambassador to explore your background and motivation for the role. You will need to complete this step within 3 days, otherwise we won't be able to move forward with your application.\\nPhone Screen - Get to know each other with a Talent Acquisition Specialist, discuss your experience and answer your questions about Mirakl\\nTechnical Interview - Deep dive with Valentin on your knowledge of Python, SQL, HTML, and APIs to assess your technical capabilities\\nBusiness Interview - Meet Laura and Heloise to discuss alignment with our company values using the STAR methodology\\nWelcome to Mirakl! - We move quickly and provide clear, transparent feedback\\n\\nWe welcome collaborators with their diverse perspectives and experiences to power us forward. These often far exceed conventional job requirements and help us create a culture of continuous learning. If you’re ready to join a global leader powering digital transformation for 450+ of the world’s most innovative retailers and B2B organizations.\\n\\nWe may use Artificial Intelligence (AI) solutions to help streamline our hiring process, including screening applications, analyzing resumes, and assessing responses. While AI helps us work efficiently, all final hiring decisions are made by humans. For more information, visit our AI Guidelines for Candidates and Interviews.\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\n\n",
      "7                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Descriptif du poste\\n\\nLieu : Vélizy-Villacoublay, France\\n\\nConstruisons ensemble un avenir de confiance\\n\\nThales est un leader mondial des hautes technologies spécialisé dans trois secteurs d’activité : Défense & Sécurité, Aéronautique & Spatial, et Cyber & Digital. Il développe des produits et solutions qui contribuent à un monde plus sûr, plus respectueux de l’environnement et plus inclusif. Le Groupe investit près de 4 milliards d’euros par an en Recherche & Développement, notamment dans des domaines clés de l’innovation tels que l’IA, la cybersécurité, le quantique, les technologies du cloud et la 6G. Thales compte près de 81 000 collaborateurs dans 68 pays. ​\\n\\nNos engagements, vos avantages\\n\\nNotre savoir-faire technologique\\n\\nNotre attention portée à l’équilibre des collaborateurs\\n\\nUn environnement inclusif et bienveillant\\n\\nUn engagement sociétal et environnemental reconnu (Thales Solidarity, indice CAC 40 ESG…)\\n\\nVotre quotidien\\nRejoignez-nous sur le campus Vélizy qui héberge une grande diversité d’activités Thales, aéro, défense, civile,… A l'ouest de Paris, ce site offre un environnement de travail équipé des dernières innovations technologiques et propose des services permettant de concilier vie professionnelle et personnelle.\\n\\nLe Cost Office rattaché à la Direction des Opérations des activités Systèmes Terrestres et Aériens vise à développer les connaissances en estimation de coûts et à challenger les modèles de coûts utilisés dans les Projets. Le Cost Office cherche à améliorer la compétitivité, intervenant tout au long du cycle de vie des projets et produits. Un Projet de capitalisation des données d’exécution des projets vise à comparer les modèles de coûts théoriques avec la réalité des dépenses. L’analyse des données et la mise en forme pour une comparaison efficace des modèles et des métriques est indispensable.\\n\\nEn tant que Data Analyst en alternance, rattaché au responsable Cost Office, votre mission principale sera d’accompagner la mise en œuvre du Projet d’amélioration des modèles de couts confié au Data Lab et à l’équipe IS/IT.\\n\\nEn nous rejoignant, vous vous verrez confier les missions suivantes :\\n\\nPréparer et animer des ateliers avec des interlocuteurs métiers et SI dans un but de cadrage\\nCorréler les données d’exécution de Projets et les données et modèles de coûts des devis\\nIdentifier les écarts de métriques associées\\nMettre en place une boucle dynamique de correction de ces métriques par interpolation des modèles statistiques\\nDévelopper les automatisations nécessaires pour permettre aux équipes de réaliser des scénarii de devis avec des paramètres modifiés ou nouveaux\\nAdapter la solution à l’évolution des technologies de la chaîne BI automatisée avec des datawarehouses adaptés aux besoins des métiers en cohérence avec la stratégie Groupe.\\nVotre profil\\n\\nVous suivez un cursus ingénieur spécialisé en informatique et traitement de la donnée et vous recherchez une alternance de 2 ans et un rythme de 3 jours / 2 jours idéalement ?\\n\\nVous avez de solides connaissances en :\\n\\nBases de données et SQL\\nPower BI\\nLangages de Programmation en lien avec le traitement des données comme Python\\n\\nIdéalement vous maîtrisez les problématiques et biais liés à l’analyse de données ?\\n\\nAvoir une première expérience en gestion de problématiques d’Ingénierie et en maîtrise des modèles de coûts paramétriques est un plus.\\n\\nOn vous reconnait pour votre force de proposition, votre rigueur, votre esprit analytique et de synthèse ainsi que pour votre bon relationnel ?\\n\\nAlors cette alternance est faite pour vous !\\n\\nMot de l'équipe\\n\\nLa capitalisation a été structurée. Il faut maintenant la mettre en forme (statistiques, modèles, indicateurs) afin d’optimiser la compétitivité sur les futurs Projets. Cette alternance permet d’accéder à de nombreuses fonctions de l’entreprise, concernées par la capitalisation des coûts pour optimiser les futurs Projets.\\n\\nThales, entreprise Handi-Engagée, reconnait tous les talents. La diversité est notre meilleur atout. Postulez et rejoignez nous !\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\n\n",
      "8                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          Descriptif du poste\\n\\nLieu : Cannes, France\\n\\nConstruisons ensemble un avenir de confiance\\n\\nThales est un leader mondial des hautes technologies spécialisé dans trois secteurs d’activité : Défense & Sécurité, Aéronautique & Spatial, et Cyber & Digital. Il développe des produits et solutions qui contribuent à un monde plus sûr, plus respectueux de l’environnement et plus inclusif. Le Groupe investit près de 4 milliards d’euros par an en Recherche & Développement, notamment dans des domaines clés de l’innovation tels que l’IA, la cybersécurité, le quantique, les technologies du cloud et la 6G. Thales compte près de 81 000 collaborateurs dans 68 pays. ​\\n\\nNos engagements, vos avantages\\n\\nNotre savoir-faire technologique\\n\\nNotre attention portée à l’équilibre des collaborateurs\\n\\nUn environnement inclusif et bienveillant\\n\\nUn engagement sociétal et environnemental reconnu (Thales Solidarity, indice CAC 40 ESG…)\\n\\nVotre quotidien\\nLe site de Cannes est en charge de la conception des systèmes satellitaires & plateformes, de l’assemblage/intégration/test des satellites ainsi que des opérations en orbite. Le site a une expertise en instrumentation optique et en avionique.\\n\\nSur le site de Cannes , au sein des Opérations, vous intègrerez la Direction « Bids & Programs Management  »  (BPM),  vous  travaillerez  dans  une  équipe  de  4  personnes  afin  de  développer  et améliorer les outils logiciels et de Business Intelligence qui participent à l’Excellence Opérationnelle. Dans  le  cadre  de  la  Transformation  Digitale  de  BPM,  il  devient  indispensable  d'automatiser  la collection, le stockage, le traitement et la restitution des données de type Charges, Plannings, Risques, Anticipations.  Ces  données  sont  issues  de  plusieurs  sources  ayant  de  multiples  formats  rendant complexe la transition vers le Big Data et l'Industrie 4.0.\\n\\nVos principales missions seront les suivantes :\\n\\nMaintenir et faire évoluer une application web (React et Next.js) permettant aux utilisateurs finaux de lancer directement les scénarios automatisés de Dataiku depuis une interface centralisée ;\\nDévelopper de nouvelles applications pour répondre aux nouveaux besoin ;\\nDévelopper des chaînes de traitement de données sur Dataiku ;\\nDévelopper des rapports sur Power BI ;\\nRédiger de la documentation afin de faciliter la prise en main des outils par nos utilisateurs ;\\nAccompagner la conduite du changement.\\nVotre profil\\nAlternance – Ingénieur Développeur Application Web / Data Analyst  – (H/F)\\n\\nVotre priorité est de rejoindre un groupe industriel innovant et découvrir le monde de la défense ?\\n\\nVous avez l’ambition de valoriser vos acquis académiques en environnement industriel et développer de nouvelles compétences ?\\n\\nIssu d’une formation de niveau BAC +4 à dominante Développement logiciel/Business  et/ou Intelligence/Data et vous recherchez une alternance d’une durée de 12 mois ?\\n\\nVous  avez  des  compétences  en  Business  Intelligence  (Power  BI)  et  traitement  de  données  (ETL  : Python, Dataiku) ?\\nVous êtes à l’aise avec le développement Web : HTML, CSS, JS et Frameworks associés : React, Next.js ?\\nVotre niveau d’anglais vous permet de lire, écrire et parler avec des termes techniques\\nVous avez des connaissances en librairies Python (Pandas, NumPy), traitement des données (Talend) ?\\n\\nRigueur, bonne capacité d’analyse, autonomie et esprit de synthèse sont des atouts que l'on vous reconnait?\\n\\nAlors ce poste est fait pour vous !\\n\\nLe mot de l’équipe\\n\\nNous offrons :• Une expérience enrichissante dans un environnement stimulant et dynamique.• La possibilité de travailler sur des projets concrets ayant un impact direct surl'entreprise.• Un encadrement par des professionnels expérimentés.Nous avons hâte de voir les contributions que vous pourrez apporter à notre équipe !\\n\\nThales, entreprise Handi-Engagée, reconnait tous les talents. La diversité est notre meilleur atout. Postulez et rejoignez nous !\\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\n\n",
      "9                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 Descriptif du poste\\n\\nMissions:\\n\\n \\n\\nAutomatisation des processus de traitement\\nAssister l’équipe dans l’automatisation des processus de collecte et de traitement des données, en développant des solutions via Phyton et SQL.\\nCollaborer avec les différents services pour identifier les besoins d'automatisation propres à l’équipe et proposer des solutions adaptées qui amélioreront la productivité et la fiabilité des traitements.\\n\\nSuivi et amélioration continue des outils automatisés :\\n\\nAssurer le suivi de l’utilisation des outils automatisés mis en place et proposer des ajustements ou améliorations en fonction des retours d’expérience des souscripteurs\\nRédiger des procédures pour l'utilisation des outils automatisés et former les équipes internes à leur utilisation.\\nParticipation aux projets transverses :\\nParticiper aux projets transverses visant à automatiser les échanges de données entre l'équipe souscription et les équipes de contrôle. \\n\\n \\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nDescription du profil :\\n\\n\\n\\nVous recherchez une alternance dans le cadre d’un Master Informatique / data avec un fort intérêt pour les outils DATA.\\nCompétences en gestion des données : Maîtrise de la suite Power BI (Power Pivot, Power Query), SQL, PHYTON et une capacité à développer des outils automatisés.\\nCompétences analytiques : Capacité à analyser des données et à proposer des solutions pour simplifier et automatiser les processus existants.\\nQualités requises : Sens de l’analyse, rigueur, capacité à travailler en équipe, et autonomie dans la gestion de projets d’automatisation.\\n\\n\\nNous proposons :\\n\\n\\n\\nNous rejoindre, c’est : ​\\n\\n \\n\\nintégrer une entreprise dynamique qui place l’innovation et la durabilité au cœur de sa stratégie\\nrelever des challenges, faire preuve d’initiative et organiser son travail en mode hybride\\nconstruire sa carrière et développer ses compétences\\nse nourrir des différences de chacun dans une entreprise qui mène des actions concrètes en faveur de la diversité, l’équité et l’inclusion \\navoir la possibilité de s’engager au sein de notre fondation The Human Safety Net, pour soutenir les personnes vulnérables et participer à l’impact positif que nous générons.\\n\\n \\n\\nPour en savoir plus, visitez notre site\\n\\nGenerali veille au respect de l’égalité de traitement des candidats lors du processus de recrutement. Les candidatures seront traitées par ordre d’arrivée. Engagé en faveur de l’égalité des chances, Generali étudie avec la plus grande attention les candidatures de personnes en situation de handicap et leurs éventuels besoins spécifiques\\n\\nVoir plus\n",
      "10                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              Descriptif du poste\\n\\nVos missions\\n\\nIntégré au sein de notre Service Line Operations & Product Services, vous évoluerez au sein d’une équipe agile avec les responsabilités suivantes : \\n\\nParticiper aux ateliers métiers pour structurer les besoins et contribuer à la rédaction des spécifications fonctionnelles\\nRéaliser des analyses sur les donnés au travers de requêtes SQL et traitement des données via Python\\nConcevoir ou améliorer des dashboards (Power BI, Tableau…) en s’assurant de la qualité des indicateurs métiers\\nExplorer les données, détecter les tendances et préparer des restitutions claires pour les équipes métiers\\nDocumenter les analyses et proposer des améliorations pour optimiser les processus et pour améliorer les qualités des données\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nDescription du profil :\\n\\nVotre profil\\n\\n• Actuellement en dernière année d’école d’ingénieurs ou en Master en système d’informations (type MIAGE)\\n\\n• Vous maîtrisez SQL, Python et Power BI\\n\\n• Aisance en anglais (Niveau B2 minimum)\\n\\n• Excellentes capacités relationnelles et goût prononcé pour le travail en équipe\\n\\n• Autonme, dynamique, vous faites preuve de curiosité et d’implication pour réussir dans vos missions\\n\\n \\n\\nInformations complémentaires\\n\\n• Contrat d’apprentissage\\n\\n• Durée d’un an\\n\\n• Rythme de l’alternance privilégié : 3sm/1sm ou 2j/3j\\n\\n \\n\\n\\n\\nNous proposons :\\n\\n\\n\\n \\n\\n \\n\\nVoir plus\n",
      "11                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Descriptif du poste\\n\\nAu sein de l’agence média OMD, vous participerez à l’activité générale de la cellule Data Analyst pour un grand groupe automobile.\\n\\nVous allez :\\n\\nAnalyser les investissements et performances des principaux médias français TV/presse/radio/affichage/digital;\\n\\nParticiper aux échanges entre les équipes Omnicom France et International sur les sujets liés à l’analyse marché/concurrence;\\n\\nParticiper à la conception et à la réalisation des études médias et marketing pour le groupe Omnicom media (audiences/investissements/insight cible…),\\n\\nSavoir traiter et restituer des données médias et marketing pour les différents parties prenantes.\\n\\nParticiper à l’élaboration de campagne média autour de différentes problématiques automobile.\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\n\\nVous êtes en cours de formation BAC+4/5 (école de commerce, science po, master communication ou études marketing).\\n\\nVous êtes curieux/se, les médias vous intéresse, vous êtes rigoureux/se et collaboratif/trice.\\n\\nLa rigueur/fiabilité et un esprit de synthèse seront essentiels pour assurer la qualité des contenus réalisés.\\n\\nDes capacités rédactionnelles, de communication orale et le travail avec enthousiasme en équipe seront indispensables.\\n\\nLa maitrise des outils bureautiques est impérative (Excel et Powerpoint en priorité).\\n\\nPetit plus si les sujets automobiles vous passionnent\\n\\nAlternance de 12 ou 24 mois à pourvoir dès le 7 septembre 2026\\n\\nRythme souhaité : 4j/1j ou 3semaines/1 semaine\\n\\nOmnicom Media s’engage pour la diversité et l’inclusion. Toutes nos offres d’emploi sont ouvertes aux travailleurs en situation de handicap.\n",
      "12                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       Descriptif du poste\\n\\nCPR Asset Management\\n\\n\\nDescription de la Direction ou de l’équipe d’accueil :\\n\\n \\n\\nLes Investment Specialists (IS) sont en charge de la mise en avant des stratégies gérées par CPRAM et contribuent au développement des expertises couvertes en termes de collecte et de promotion,. Ils travaillent en collaboration avec les analystes, les gérants, les équipes marketing et les commerciaux en France et à l’international.\\n\\n \\n\\nVous rejoindrez une équipe jeune et dynamique de 6 professionnels, dans une équipe au cœur des différents métiers de la gestion d’actifs. L’équipe est également moteur du changement et travaille sur les différents projets d’automatisation au niveau de l’entreprise.\\n\\n \\n\\nDescription de la mission :\\n\\n \\n\\nVous aurez pour principales missions de :\\n\\n \\n\\nAider au développement et à l’automatisation des processus métiers (Python, HTML, Power BI)\\nMise en place d’outil d’intelligence artificielle à partir de l’API de ChatGPT (Langchain, Data science)\\nExploiter les bases de données à disposition (Factset / Bloomberg…) afin de pouvoir mettre à jour les données de marché des différentes classes d’actifs\\nAméliorer la gouvernance et la qualité de la donnée, mise en place d’outils de data management (Python, SQL)\\nContribuer à la production de publications mensuelles à destination des équipes commerciales (performances, expositions…) via l’utilisation et le développement d’outils Excel, VBA et Python\\nAssister aux demandes techniques internes ou externes -notamment émanant de l’international- sur les stratégies d’investissement des différentes classes d’actifs\\n\\n \\n\\n \\n\\nApport de l’alternance :\\n\\n \\n\\nCette alternance offre une immersion opérationnelle au cœur de la gestion d’actifs et du data engineering : automatisation Python/SQL, intégration d’IA (LangChain, ChatGPT, Agentique, etc.), reporting commercial et gouvernance des données.\\n\\nL’alternant développera des compétences techniques (coding, data pipelines, BI), des compétences humaines, une compréhension des différentes classes d’actifs et une expérience collaborative internationale au sein d’une structure innovante.\\n\\n \\n\\nVoir plus\\n\\nEXPERIENCE REQUISE:\\nProfil recherché\\nFormation : Master 1 et/ou 2, Ingénieur\\nSpécialisation : Data Sciences avec des notions de finance de marché\\n\\n\\nCompétences en Data Science et intérêts pour l’automatisation (via Python, LangChain, etc.. )\\nConnaissances des marchés financiers\\nSoft skills : rigueur, curiosité et bon relationnel\\n\\n\\nPython\\nVBA\\nPack Office\\nLangChain (serait un plus)\\nPower BI (serait un plus)\\n\\nAnglais Courant\n",
      "13                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       